# --- Database (Railway Postgres) ---
# Railway injects this automatically when you add the Postgres plugin.
# For local dev, point it at a local Postgres instance.
DATABASE_URL="postgres://user:pass@localhost:5432/foodie"

# --- Admin auth (server-side, never shipped to the browser) ---
ADMIN_USER="admin"
ADMIN_PASSWORD="change_me_to_something_strong"

# --- Server ---
# PORT is provided by Railway automatically; default 3000 locally.
PORT="3000"

# Allowed origin for the /api/* CORS headers. Use "*" for any origin, or set it
# to your frontend URL if you host the static guide separately (e.g. Netlify).
CORS_ORIGIN="*"
